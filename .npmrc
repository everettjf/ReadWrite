# node-linker=hoisted produces a flat, npm-style node_modules. We need this
# because electron-builder follows the dep tree from package.json down and
# expects every transitive dep (including peer-dep declarations like `zod`
# under @ai-sdk/*) to live at a path it can asar-pack. With the previous
# `isolated` linker, peers landed in node_modules/.pnpm/<x>/node_modules/<y>
# and were intermittently dropped from the bundle, surfacing on a fresh Mac
# as "Cannot find package 'zod'" at runtime.
shamefully-hoist=false
strict-peer-dependencies=false
auto-install-peers=true
node-linker=hoisted
public-hoist-pattern[]=*electron*
