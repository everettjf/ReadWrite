{
  "name": "readwrite",
  "version": "0.1.1",
  "description": "Read anything. Write anywhere. A cross-platform desktop app that puts a reader and a Markdown editor side by side.",
  "private": true,
  "author": {
    "name": "everettjf",
    "email": "xnuapp@gmail.com",
    "url": "https://github.com/everettjf"
  },
  "license": "MIT",
  "homepage": "https://github.com/everettjf/ReadWrite",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/everettjf/ReadWrite.git"
  },
  "bugs": {
    "url": "https://github.com/everettjf/ReadWrite/issues"
  },
  "main": "./out/main/index.js",
  "type": "module",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "pnpm run typecheck:node && pnpm run typecheck:web",
    "lint": "eslint . --cache",
    "lint:fix": "eslint . --cache --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf out dist node_modules/.vite .turbo .eslintcache",
    "rebuild:native": "electron-builder install-app-deps",
    "package:dir": "pnpm run build && electron-builder --dir",
    "dist": "pnpm run build && electron-builder",
    "dist:mac": "pnpm run build && electron-builder --mac",
    "dist:win": "pnpm run build && electron-builder --win",
    "dist:linux": "pnpm run build && electron-builder --linux",
    "prepare": "husky || true",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.71",
    "@ai-sdk/deepseek": "^2.0.29",
    "@ai-sdk/google": "^3.0.64",
    "@ai-sdk/openai": "^3.0.53",
    "@codemirror/autocomplete": "^6.18.3",
    "@codemirror/commands": "^6.7.1",
    "@codemirror/lang-markdown": "^6.3.1",
    "@codemirror/language": "^6.10.6",
    "@codemirror/state": "^6.5.0",
    "@codemirror/theme-one-dark": "^6.1.2",
    "@codemirror/view": "^6.35.0",
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^4.0.0",
    "@milkdown/core": "^7.5.8",
    "@milkdown/ctx": "^7.5.8",
    "@milkdown/plugin-clipboard": "^7.5.8",
    "@milkdown/plugin-history": "^7.5.8",
    "@milkdown/plugin-listener": "^7.5.8",
    "@milkdown/plugin-slash": "^7.5.8",
    "@milkdown/plugin-tooltip": "^7.5.8",
    "@milkdown/plugin-upload": "^7.5.8",
    "@milkdown/preset-commonmark": "^7.5.8",
    "@milkdown/preset-gfm": "^7.5.8",
    "@milkdown/prose": "^7.5.8",
    "@milkdown/react": "^7.5.8",
    "@milkdown/theme-nord": "^7.5.8",
    "@milkdown/transformer": "^7.5.8",
    "@milkdown/utils": "^7.5.8",
    "@monaco-editor/react": "^4.6.0",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.1",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.2",
    "@radix-ui/react-tooltip": "^1.1.6",
    "@tanstack/react-query": "^5.62.7",
    "@types/diff": "^8.0.0",
    "ai": "^6.0.168",
    "better-sqlite3": "^11.6.0",
    "chokidar": "^4.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "diff": "^9.0.0",
    "electron-store": "^10.0.0",
    "epubjs": "^0.3.93",
    "gray-matter": "^4.0.3",
    "html-to-image": "^1.11.11",
    "juice": "^11.0.0",
    "lucide-react": "^0.460.0",
    "marked": "^14.1.4",
    "monaco-editor": "^0.52.2",
    "nanoid": "^5.0.9",
    "pdfjs-dist": "^4.9.155",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-reader": "^2.0.11",
    "react-resizable-panels": "^2.1.7",
    "tailwind-merge": "^2.5.5",
    "tailwindcss-animate": "^1.0.7",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@typescript-eslint/eslint-plugin": "^8.18.1",
    "@typescript-eslint/parser": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "lint-staged": "^15.2.11",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "rimraf": "^6.0.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,yml,yaml}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "esbuild"
    ]
  }
}
